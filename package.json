{
  "name": "gymnopedies",
  "private": false,
  "version": "1.1.3",
  "type": "module",
  "author": {
    "name": "shoota"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shoota/gymnopedies.git"
  },
  "description": "A shadcn/ui registry of dark-themed, blog-oriented React components.",
  "scripts": {
    "dev": "vite",
    "dev:examples": "vite --config ./examples/blog/vite.config.ts",
    "dev:examples:https": "HTTPS=1 vite --config ./examples/blog/vite.config.ts",
    "build": "vite build",
    "build:examples": "vite build --config ./examples/blog/vite.config.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "typecheck": "tsc -p ./tsconfig.typecheck.json && tsc -p ./examples/blog/tsconfig.json",
    "preview": "vite preview",
    "preview:examples": "vite preview --config ./examples/blog/vite.config.ts",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006 --https --ssl-ca ./localhost.pem --ssl-cert ./localhost.pem --ssl-key ./localhost-key.pem",
    "storybook:plain": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "registry:generate": "tsx scripts/build-registry.ts",
    "registry:build": "npm run registry:generate && npx shadcn@latest build",
    "chromatic": "npx chromatic --project-token=chpt_4388496fa226214"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.474.0",
    "next-themes": "^0.4.6",
    "react-resizable-panels": "^4.11.0",
    "recharts": "^3.8.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/cz-commitlint": "^20.5.3",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/addon-links": "^9.1.20",
    "@storybook/addon-onboarding": "^9.1.20",
    "@storybook/react-vite": "^9.1.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20.19.40",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-storybook": "^9.1.20",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "local-ssl-proxy": "^2.0.5",
    "prettier": "3.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "storybook": "^9.1.20",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "npx eslint --fix"
  },
  "bugs": {
    "url": "https://github.com/shoota/gymnopedies/issues"
  },
  "homepage": "https://gymnopedies.shoota.work"
}
